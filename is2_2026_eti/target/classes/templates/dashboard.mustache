<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">
            ¡Bienvenido, <span class="font-semibold text-blue-600">{{username}}</span>!
        </p>
        {{/username}}

        {{^username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido!</p>
        {{/username}}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

            <!-- ===================== -->
            <!-- PERFIL (ALUMNO + DOCENTE) -->
            <!-- ===================== -->
           {{#isAlumnoOrDocente}}

            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-blue-700 mb-3">Tu Perfil</h2>
                <p class="text-gray-600 mb-4">Gestiona la información de tu cuenta.</p>
                <a href="/profile"
                   class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">
                   Ver Perfil
                </a>
            </div>

            <div class="bg-orange-50 border border-orange-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-orange-700 mb-3">Completar Datos</h2>
                <p class="text-gray-600 mb-4">Completa o actualiza tu información personal.</p>
                <a href="/datos"
                   class="inline-block bg-orange-600 text-white py-2 px-4 rounded-md hover:bg-orange-700 transition duration-300">
                   Completar / Editar
                </a>
            </div>

            {{/isAlumnoOrDocente}}

            <!-- Bloque para mostrar configuraciones -->
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 mb-3">Configuraciones</h2>
                <p class="text-gray-600 mb-4">Ajusta las preferencias de tu aplicación.</p>
                <a href="/settings" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Configuración</a>
            </div>

            <!-- ===================== -->
            <!-- ALUMNO -->
            <!-- ===================== -->
            {{#isAlumno}}
            <div class="bg-yellow-50 border border-yellow-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-yellow-700 mb-3">Inscribirse a Carrera</h2>
                <p class="text-gray-600 mb-4">Selecciona una carrera.</p>
                <a href="/inscripcion/carrera" class="inline-block bg-yellow-600 text-white py-2 px-4 rounded-md hover:bg-yellow-700">
                    Inscribirse
                </a>
            </div>
            {{/isAlumno}}

            <!-- ===================== -->
            <!-- DOCENTE -->
            <!-- ===================== -->
            {{#isDocente}}
            <div class="bg-purple-50 border border-purple-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-purple-700 mb-3">Mis Materias</h2>
                <p class="text-gray-600 mb-4">Ver materias asignadas.</p>
                <a href="/docente/materias" class="inline-block bg-purple-600 text-white py-2 px-4 rounded-md hover:bg-purple-700">
                    Ver Materias
                </a>
            </div>

            <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 mb-3">Subir Notas</h2>
                <p class="text-gray-600 mb-4">Gestionar calificaciones.</p>
                <a href="/docente/notas" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700">
                    Subir Notas
                </a>
            </div>
            {{/isDocente}}

            <!-- ===================== -->
            <!-- ADMINISTRADOR -->
            <!-- ===================== -->
            {{#isAdmin}}
            <div class="bg-gray-100 border border-gray-300 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-gray-800 mb-3">Gestionar Carreras</h2>
                <p class="text-gray-600 mb-4">Crear y administrar carreras.</p>
                <a href="/carrera/new" class="inline-block bg-gray-700 text-white py-2 px-4 rounded-md hover:bg-gray-800">
                    Nueva Carrera
                </a>
            </div>

            <div class="bg-gray-100 border border-gray-300 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-gray-800 mb-3">Asignar Docentes</h2>
                <p class="text-gray-600 mb-4">Asignar docentes a materias.</p>
                <a href="/admin/asignar-docente" class="inline-block bg-gray-700 text-white py-2 px-4 rounded-md hover:bg-gray-800">
                    Asignar
                </a>
            </div>
            {{/isAdmin}}

        </div>
        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">
                Cerrar Sesión
            </a>
        </div>
    </div>

</div>
</body>
</html>
