<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Nueva Carrera</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen p-6">

<div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-4xl">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Nueva Carrera</h1>

        <a href="/dashboard"
           class="bg-gray-500 text-white px-4 py-2 rounded-md hover:bg-gray-600">
            ← Volver
        </a>
    </div>

    <form method="post" action="/admin/carrera" onkeydown="return event.key != 'Enter';">
        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
            {{.}}
        </div>
        {{/error}}
        {{#success}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
            {{.}}
        </div>
        {{/success}}

        <!-- DATOS PRINCIPALES -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

            <input name="nombre_carrera" placeholder="Nombre de la carrera"
                   class="border p-2 rounded w-full" required>

            <input name="anios" type="number" min="1"
                   class="border p-2 rounded w-full" placeholder="Cantidad de años" required>

            <select name="id_facultad"
                    class="border p-2 rounded w-full">
                {{#facultades}}
                <option value="{{id_facultad}}">{{nombre}}</option>
                {{/facultades}}
            </select>
        </div>

        <!-- MATERIAS -->
        <div id="contenedorAnios"></div>

        <!-- BOTÓN -->
        <div class="mt-6 text-center">
            <button type="submit"
                class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700">
                Guardar Carrera
            </button>
        </div>

    </form>
</div>

<script>
const inputAnios = document.querySelector("input[name='anios']");
const contenedor = document.getElementById("contenedorAnios");

inputAnios.addEventListener("change", () => {
    contenedor.innerHTML = "";
    const anios = parseInt(inputAnios.value);

    for (let i = 1; i <= anios; i++) {
        const bloque = document.createElement("div");

        bloque.className = "mb-6 border rounded-lg p-4 bg-gray-50";

        bloque.innerHTML = `
            <h2 class="font-bold text-lg mb-3">Año ${i}</h2>

            <div id="anio_${i}"></div>

            <button type="button"
                onclick="agregarMateria(${i})"
                class="mt-2 bg-green-600 text-white px-3 py-1 rounded">
                + Agregar Materia
            </button>
        `;

        contenedor.appendChild(bloque);
    }
});

function agregarMateria(anio) {
    const cont = document.getElementById("anio_" + anio);
    const index = cont.children.length;

    const div = document.createElement("div");
    div.className = "grid grid-cols-5 gap-2 mb-2";

    div.innerHTML = `
    <input name="materia_codigo_${anio}_${index}" placeholder="Código" class="border p-2 rounded" required>
    <input name="materia_nombre_${anio}_${index}" placeholder="Nombre" class="border p-2 rounded" required>
    <input name="materia_horas_${anio}_${index}" type="number" placeholder="Horas" class="border p-2 rounded" required>

    <select name="materia_cuatri_${anio}_${index}" class="border p-2 rounded">
        <option value="">Cuatrimestre</option>
        <option value="1C">1° Cuatrimestre</option>
        <option value="2C">2° Cuatrimestre</option>
        <option value="ANUAL">Anual</option>
    </select>

    <button type="button" onclick="this.parentElement.remove()" class="text-red-500 font-bold">✕</button>
    `;
    cont.appendChild(div);
}
</script>

</body>
</html>