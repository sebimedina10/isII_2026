<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Completar Datos</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen">

    <div class="bg-white p-8 rounded shadow-md w-full max-w-lg">
        <h2 class="text-2xl font-bold mb-4 text-center">Completar Datos</h2>
        {{#errorMessage}}
        <div class="bg-red-200 p-2 mb-2">{{errorMessage}}</div>
        {{/errorMessage}}

        {{#successMessage}}
        <div class="bg-green-200 p-2 mb-2">{{successMessage}}</div>
        {{/successMessage}}

        <div style="margin-bottom: 20px;">
            <a href="/dashboard" style="display: inline-block; padding: 10px 20px; background-color: #007bff; color: white; text-decoration: none; border-radius: 5px;">
                ← Volver al Dashboard
            </a>
        </div>

        <form action="/datos" method="post">

            <!-- PERSONA -->
            <input type="number" name="dni" placeholder="DNI" class="w-full mb-2 p-2 border" required>
            <input type="text" name="nombre" placeholder="Nombre" class="w-full mb-2 p-2 border" required>
            <input type="text" name="apellido" placeholder="Apellido" class="w-full mb-2 p-2 border" required>
            <input type="email" name="email" placeholder="Email" class="w-full mb-2 p-2 border" required>
            <input type="text" name="telefono" placeholder="Ej: 3584112233" value="{{telefono}}" class="w-full mb-2 p-2 border">
            <label class="block text-gray-700 text-sm font-bold mb-1">Fecha de Nacimiento</label>
            <div class="flex gap-2 mb-4">
                <!-- Día -->
                <select name="dia" id="dia" class="w-1/3 p-2 border rounded bg-white">
                    <option value="">Día</option>
                </select>

                <!-- Mes -->
                <select name="mes" id="mes" class="w-1/3 p-2 border rounded bg-white">
                    <option value="">Mes</option>
                    <option value="01">Enero</option>
                    <option value="02">Febrero</option>
                    <option value="03">Marzo</option>
                    <option value="04">Abril</option>
                    <option value="05">Mayo</option>
                    <option value="06">Junio</option>
                    <option value="07">Julio</option>
                    <option value="08">Agosto</option>
                    <option value="09">Septiembre</option>
                    <option value="10">Octubre</option>
                    <option value="11">Noviembre</option>
                    <option value="12">Diciembre</option>
                </select>

                <!-- Año -->
                <select name="anio" id="anio" class="w-1/3 p-2 border rounded bg-white">
                    <option value="">Año</option>
                </select>
            </div>

            <!-- ===================== -->
            <!-- DOCENTE -->
            <!-- ===================== -->
            {{#isDocente}}
            <div class="bg-purple-50 p-4 rounded mt-4">
                <h3 class="font-bold mb-2 text-purple-700">Datos de Docente</h3>
                <input type="text" name="titulo" placeholder="Título" class="w-full mb-2 p-2 border">
                <select name="rol" class="w-full mb-2 p-2 border">
                    <option value="">Seleccionar rol</option>
                    <option value="RESPONSABLE">Responsable</option>
                    <option value="JTP">JTP</option>
                    <option value="AYUDANTE">Ayudante</option>
                </select>

                <select name="id_facultad" class="w-full mb-2 p-2 border">
                    <option value="">Seleccionar facultad</option>
                    {{#facultades}}
                    <option value="{{id_facultad}}">{{nombre}}</option>
                    {{/facultades}}
                </select>

            </div>
            {{/isDocente}}
            <!-- ===================== -->
            <!-- ALUMNO -->
            <!-- ===================== -->
            {{#isAlumno}}
            <div class="bg-yellow-50 p-4 rounded mt-4">
                <h3 class="font-bold mb-2 text-yellow-700">Datos de Alumno</h3>
                <p class="text-gray-600">Tus datos académicos se inicializan automáticamente.</p>
            </div>

            {{/isAlumno}}
            <button type="submit"
            class="bg-blue-500 text-white px-4 py-2 w-full mt-4">
            Guardar
        </button>
    </form>
</div>

<script>
    const selectDia = document.getElementById('dia');
    const selectMes = document.getElementById('mes');
    const selectAnio = document.getElementById('anio');

    // 1. Llenar select de Años (1950 a 2015)
    for (let i = 2015; i >= 1950; i--) {
        let opt = document.createElement('option');
        opt.value = i;
        opt.innerHTML = i;
        // Si ya teníamos un año guardado (pasado desde Java)
        if ("{{anio_val}}" == i) opt.selected = true;
        selectAnio.appendChild(opt);
    }

    // 2. Función para actualizar días según mes y año
    function actualizarDias() {
        const mes = parseInt(selectMes.value);
        const anio = parseInt(selectAnio.value);
        let diasEnMes = 31;

        if (mes === 4 || mes === 6 || mes === 9 || mes === 11) {
            diasEnMes = 30;
        } else if (mes === 2) {
            // Cálculo de bisiesto
            const esBisiesto = (anio % 4 === 0 && (anio % 100 !== 0 || anio % 400 === 0));
            diasEnMes = esBisiesto ? 29 : 28;
        }

        // Guardamos el día que estaba seleccionado para no perderlo
        const diaSeleccionado = selectDia.value || "{{dia_val}}";

        selectDia.innerHTML = '<option value="">Día</option>';
        for (let i = 1; i <= diasEnMes; i++) {
            let opt = document.createElement('option');
            let val = i < 10 ? '0' + i : i.toString();
            opt.value = val;
            opt.innerHTML = i;
            if (val == diaSeleccionado) opt.selected = true;
            selectDia.appendChild(opt);
        }
    }

    // Escuchar cambios
    selectMes.addEventListener('change', actualizarDias);
    selectAnio.addEventListener('change', actualizarDias);

    // Si venimos de la BD, marcamos el mes correcto
    if ("{{mes_val}}") {
        selectMes.value = "{{mes_val}}";
    }

    // Ejecutar al cargar para inicializar los días
    actualizarDias();
</script>

</body>
</html>